# SMTP credentials for the /api/contact route.
# On Netlify set these under Site → Settings → Environment variables.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Where contact-form submissions are delivered
CONTACT_TO_EMAIL=contact@barqova.com

# Optional. Defaults to SMTP_USER if unset.
# Format: "Name <address@domain.com>"
CONTACT_FROM_EMAIL=
